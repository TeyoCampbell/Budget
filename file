// ── CSV IMPORT ──────────────────────────────────────────────
let csvRows = [], csvHeaders = [];

function openImportModal() {
  document.getElementById('import-step-1').style.display = '';
  document.getElementById('import-step-2').style.display = 'none';
  document.getElementById('import-step-3').style.display = 'none';
  document.getElementById('csv-error').style.display = 'none';
  document.getElementById('csv-file-input').value = '';
  document.getElementById('import-modal').classList.add('open');
}
function closeImportModal() {
  document.getElementById('import-modal').classList.remove('open');
  csvRows = []; csvHeaders = [];
}
function backToStep1() {
  document.getElementById('import-step-1').style.display = '';
  document.getElementById('import-step-2').style.display = 'none';
  document.getElementById('csv-error').style.display = 'none';
}

function handleCsvFile(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => parseCsv(e.target.result);
  reader.readAsText(file);
}

const dropZone = document.getElementById('csv-drop-zone');
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.borderColor = 'var(--text-primary)'; });
dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = 'var(--border-md)'; });
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.style.borderColor = 'var(--border-md)'; const f = e.dataTransfer.files[0]; if(f) handleCsvFile(f); });

function parseCsv(text) {
  const lines = text.trim().split(/\r?\n/).filter(l => l.trim());
  if (lines.length < 2) { showCsvError('File appears empty or has only one row.'); return; }
  function splitLine(line) {
    const result = []; let cur = '', inQ = false;
    for (let i = 0; i < line.length; i++) {
      const c = line[i];
      if (c === '"') { inQ = !inQ; }
      else if (c === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
      else { cur += c; }
    }
    result.push(cur.trim());
    return result;
  }
  csvHeaders = splitLine(lines[0]).map(h => h.replace(/^"|"$/g,'').trim());
  csvRows = lines.slice(1).map(l => splitLine(l).map(v => v.replace(/^"|"$/g,'').trim()));
  if (csvHeaders.length < 2) { showCsvError('Could not detect columns. Make sure the file is comma-separated.'); return; }
  autoMapColumns();
  buildColumnSelects();
  showPreview();
  document.getElementById('import-step-1').style.display = 'none';
  document.getElementById('import-step-2').style.display = '';
  document.getElementById('import-preview-info').textContent = `Found ${csvRows.length} transactions in ${csvHeaders.length} columns.`;
}

function showCsvError(msg) {
  const el = document.getElementById('csv-error');
  el.textContent = msg; el.style.display = '';
}

function autoMapColumns() {
  const h = csvHeaders.map(x => x.toLowerCase());
  const find = (...terms) => { for (const t of terms) { const i = h.findIndex(x => x.includes(t)); if(i>=0) return i; } return 0; };
  window._colDate   = find('date','time','posted');
  window._colDesc   = find('description','memo','name','payee','narrative','merchant','details');
  window._colAmount = find('amount','debit','withdrawal','charge');
  window._colCredit = h.findIndex(x => x.includes('credit') || x.includes('deposit'));
  const amtIdx = window._colAmount;
  const sampleAmts = csvRows.slice(0,10).map(r => parseFloat((r[amtIdx]||'').replace(/[$,\s]/g,'')));
  const hasNeg = sampleAmts.some(v => v < 0);
  const sel = document.getElementById('import-type-default');
  if (hasNeg && !sel.querySelector('[value="mixed"]')) {
    const opt = document.createElement('option'); opt.value='mixed'; opt.textContent='Auto-detect (negative = expense, positive = income)';
    sel.insertBefore(opt, sel.firstChild);
  }
  sel.value = hasNeg ? 'mixed' : 'expense';
}

function buildColumnSelects() {
  ['col-date','col-desc','col-amount','col-credit'].forEach(id => {
    const sel = document.getElementById(id);
    sel.innerHTML = id === 'col-credit' ? '<option value="">— none —</option>' : '';
    csvHeaders.forEach((h,i) => { const opt = document.createElement('option'); opt.value=i; opt.textContent=h; sel.appendChild(opt); });
  });
  document.getElementById('col-date').value   = window._colDate;
  document.getElementById('col-desc').value   = window._colDesc;
  document.getElementById('col-amount').value = window._colAmount;
  if (window._colCredit >= 0) {
    document.getElementById('col-credit').value = window._colCredit;
    document.getElementById('col-credit-row').style.display = '';
  }
  ['col-date','col-desc','col-amount','col-credit','import-type-default'].forEach(id => {
    document.getElementById(id).addEventListener('change', showPreview);
  });
}

function showPreview() {
  const di = +document.getElementById('col-date').value;
  const ni = +document.getElementById('col-desc').value;
  const ai = +document.getElementById('col-amount').value;
  const ci = document.getElementById('col-credit').value;
  const typeMode = document.getElementById('import-type-default').value;
  const preview = csvRows.slice(0, 4);
  const el = document.getElementById('import-preview-rows');
  el.innerHTML = '<div style="font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">Preview (first 4 rows)</div>' +
    preview.map(r => {
      const rawAmt = (r[ai]||'').replace(/[$,\s]/g,'');
      const creditRaw = ci ? (r[+ci]||'').replace(/[$,\s]/g,'') : '';
      let amt = parseFloat(rawAmt) || 0, type = 'expense';
      if (typeMode === 'mixed') { type = amt < 0 ? 'expense' : 'income'; amt = Math.abs(amt); }
      else if (typeMode === 'income') { type = 'income'; amt = Math.abs(amt); }
      else { if (creditRaw && parseFloat(creditRaw) > 0) { type='income'; amt=parseFloat(creditRaw); } else { amt = Math.abs(amt); } }
      const color = type==='income'?'#0F6E56':'var(--text-primary)';
      return `<div class="preview-row"><span>${r[di]||'—'}</span><span style="flex:2;">${r[ni]||'—'}</span><span style="color:${color};text-align:right;">${type==='income'?'+':'-'}$${Math.abs(amt).toFixed(2)}</span></div>`;
    }).join('');
}

function guessCategory(desc) {
  const d = desc.toLowerCase();
  if (/grocery|grocer|whole food|trader joe|aldi|kroger|safeway|publix|instacart/.test(d)) return 'Food';
  if (/restaurant|cafe|coffee|starbuck|mcdonald|chipotle|pizza|sushi|doordash|uber eat|grubhub|food|diner|tavern/.test(d)) return 'Food';
  if (/uber|lyft|transit|metro|bus |train|parking|shell|exxon|chevron|bp |gas |fuel|mta/.test(d)) return 'Transport';
  if (/rent|mortgage|hoa|apartment|lease/.test(d)) return 'Housing';
  if (/netflix|spotify|hulu|disney|amazon prime|hbo|apple tv|cinema|movie|theater|concert|ticketmaster/.test(d)) return 'Entertainment';
  if (/pharmacy|cvs|walgreen|doctor|dentist|hospital|medical|health|gym|fitness|yoga/.test(d)) return 'Health';
  if (/amazon|target|walmart|costco|best buy|shop|store|online|mall/.test(d)) return 'Shopping';
  return 'Other';
}

function confirmImport() {
  const di = +document.getElementById('col-date').value;
  const ni = +document.getElementById('col-desc').value;
  const ai = +document.getElementById('col-amount').value;
  const ci = document.getElementById('col-credit').value;
  const typeMode = document.getElementById('import-type-default').value;
  let imported = 0, skipped = 0;
  csvRows.forEach(r => {
    const dateStr = (r[di]||'').trim();
    const desc = (r[ni]||'').trim();
    const rawAmt = (r[ai]||'').replace(/[$,\s]/g,'');
    const creditRaw = ci ? (r[+ci]||'').replace(/[$,\s]/g,'') : '';
    if (!desc || (!rawAmt && !creditRaw)) { skipped++; return; }
    let amt = parseFloat(rawAmt) || 0, type = 'expense';
    if (typeMode === 'mixed') { type = amt < 0 ? 'expense' : 'income'; amt = Math.abs(amt); }
    else if (typeMode === 'income') { type = 'income'; amt = Math.abs(amt); }
    else { if (creditRaw && parseFloat(creditRaw) > 0) { type='income'; amt=parseFloat(creditRaw); } else { amt = Math.abs(amt); } }
    if (amt <= 0) { skipped++; return; }
    let month = currentMonth, year = currentYear;
    const d = new Date(dateStr);
    if (!isNaN(d.getTime())) { month = d.getMonth(); year = d.getFullYear(); }
    const cat = type === 'expense' ? guessCategory(desc) : '';
    const shortDate = MONTHS[month] + (isNaN(d.getTime()) ? '' : ' ' + d.getDate());
    transactions.push({ id: nextId++, type, desc, amount: amt, cat, month, year, date: shortDate });
    imported++;
  });
  save();
  document.getElementById('import-step-2').style.display = 'none';
  document.getElementById('import-step-3').style.display = '';
  document.getElementById('import-success-msg').textContent = `${imported} transaction${imported!==1?'s':''} imported`;
  document.getElementById('import-success-sub').textContent = skipped > 0 ? `${skipped} rows skipped (empty or invalid)` : 'All rows imported successfully';
  render();
}
// ── END CSV IMPORT ───────────────────────────────────────────

render();
</script>
